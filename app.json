{
  "expo": {
    "name": "Bookly Flow",
    "slug": "bookly-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-owk.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-owk.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.booklyflow.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-owk.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.booklyflow.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "booklyflow",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://vhy3fcvv38j7g23yz7m8bxke9chk8cgj.app.specular.dev"
    }
  }
}