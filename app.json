{
  "expo": {
    "name": "Bookly Flow",
    "slug": "bookly-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-owk.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-owk.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.placeholder.app.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-owk.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.placeholder.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "booklyflow",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://vhy3fcvv38j7g23yz7m8bxke9chk8cgj.app.specular.dev",
      "oneSignalAppId": "3e6a213e-27d9-4d48-8f71-61de9d57f251"
    }
  }
}